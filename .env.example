# =========================================================================
# openclob agent configuration. Copy to .env and fill in.
# =========================================================================

# ---- Runtime mode ----
# One of: backtest | paper | dryrun | live
AGENT_MODE=paper

# Bankroll in USD-equivalent. Hard-capped by phase regardless.
AGENT_BANKROLL=50

# Cycle period for --loop in seconds.
AGENT_CYCLE_SECONDS=1200

# Comma-separated list of allowed categories. Use 'all' to allow any.
AGENT_CATEGORIES=geopolitics,world,politics

# Hard per-market position cap in USD.
AGENT_PER_MARKET_CAP=2

# Max simultaneous open positions.
AGENT_MAX_POSITIONS=8

# Daily loss circuit-breaker (fraction of bankroll). 0.20 = 20%.
AGENT_DAILY_LOSS_CAP=0.20

# ---- LLM (AWS Bedrock) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: only if using temporary credentials
AWS_SESSION_TOKEN=

# Model selector. Examples:
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0
#   us.anthropic.claude-haiku-4-5-20251001-v1:0
#   us.anthropic.claude-opus-4-7-20251201-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Cheap model used for ambiguity-check pre-filter. Falls back to BEDROCK_MODEL_ID if unset.
BEDROCK_MODEL_ID_CHEAP=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Per-decision soft cap (USD) and per-day hard cap (USD).
LLM_PER_DECISION_USD_CAP=0.05
LLM_PER_DAY_USD_CAP=5.00

# Approximate $/1M tokens for the configured model. Used for budget accounting.
# Defaults match Claude Sonnet 4.5 list price; override if you switch models.
LLM_INPUT_USD_PER_MTOK=3.00
LLM_OUTPUT_USD_PER_MTOK=15.00

# ---- Search (Tavily) ----
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=8

# ---- Manifold (paper trading) ----
MANIFOLD_API_KEY=
MANIFOLD_BASE_URL=https://api.manifold.markets

# ---- Polymarket (live) ----
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYGON_RPC_URL=https://polygon-rpc.com
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
# Signature type: 0 = EOA, 1 = poly-proxy, 2 = poly-gnosis-safe
POLYMARKET_SIG_TYPE=0
POLYMARKET_CHAIN_ID=137

# ---- Storage / observability ----
AGENT_DB_PATH=data/agent.db
AGENT_LOG_PATH=logs/agent.jsonl
AGENT_LOG_LEVEL=INFO

# Optional webhook (Slack-compatible) for alerts.
ALERT_WEBHOOK_URL=
